# Copy this to .env and fill in your values
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-at-least-32chars

# Optional OAuth (get these from Google Cloud Console / GitHub Developer Settings)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional SMTP - use https://ethereal.email for free test accounts
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
